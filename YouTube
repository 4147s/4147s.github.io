@charset "utf-8";

#copyright-school { max-width: 800px; }

#copyright-school-action-container, .copyright-school-choices, .copyright-school-correct-incorrect { padding-top: 8px; }

#copyright-school-content { overflow: auto; line-height: 1.5; }

#copyright-school-header { padding: 30px 0px 15px; font-size: 16px; }

#copyright-school-instructions { margin-top: 15px; }

#copyright-school-instructions-steps, #copyright-school-question-list { list-style-type: decimal; }

#copyright-school-instructions-steps, #copyright-school-question-list, .copyright-school-question-multiple-choices { list-style-position: inside; }

.copyright-school-question { padding: 8px 0px; }

#copyright-school-question-choices { list-style-type: none; }

#copyright-school-question-column { float: right; margin: 0px 20px 0px 0px; border-left: 1px solid rgb(241, 241, 241); padding-left: 20px; width: 300px; }

#copyright-school-video-column { float: left; margin: 0px; border: 0px; padding-right: 20px; width: 400px; }

#copyright-school-video-column iframe { width: 400px; height: 230px; }

#video-takedown-notification { max-width: 800px; }

.video-takedown-notification-body { padding: 0px 5px; line-height: 18px; }

.video-takedown-notification-body-heading { padding-top: 20px; }

.video-takedown-notification-body-video-details { padding-top: 20px; display: inline-block; padding-right: 10px; height: 100px; }

.video-takedown-notification-heading { display: inline-block; max-width: 590px; margin: 70px 0px 0px 30px; vertical-align: top; font-size: 16px; }

.video-takedown-notification-heading-body-divider { position: absolute; top: 132px; z-index: -1; border-top: 1px solid rgb(241, 241, 241); width: 800px; }

.video-takedown-notification-title { padding-bottom: 5px; }

.video-takedown-notification-strike-warning { font-weight: normal; }

.copyright-school-incorrect { color: red; }

.copyright-school-correct { color: green; }
